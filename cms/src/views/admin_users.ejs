<%- include("partials/layout_top", { title: "Admin - Users" }) %>

<div class="flex items-center justify-between gap-3">
  <h2 class="text-lg font-semibold">用戶列表</h2>
  <div class="flex flex-wrap items-center gap-2">
    <a class="rounded-lg bg-white px-3 py-2 text-sm font-medium text-slate-900 ring-1 ring-slate-200 hover:bg-slate-50" href="/admin/export.xlsx">Export xlsx</a>
    <button
      type="button"
      id="btnOpenClear"
      class="rounded-lg bg-rose-600 px-3 py-2 text-sm font-medium text-white hover:bg-rose-700"
    >Clear 全部資料</button>
    <form method="post" action="/admin/logout">
      <button class="rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800" type="submit">登出</button>
    </form>
  </div>
</div>

<% if (typeof cleared !== 'undefined' && cleared) { %>
  <div class="mt-4 rounded-lg bg-emerald-50 px-3 py-2 text-sm text-emerald-800">已清除所有 users、plays、surveys 資料。</div>
<% } %>
<% if (typeof clearError !== 'undefined' && clearError) { %>
  <div class="mt-4 rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-800"><%= clearError %></div>
<% } %>

<div class="mt-4 overflow-auto rounded-xl border bg-white">
  <table class="min-w-full text-left text-sm">
    <thead class="bg-slate-50 text-xs uppercase text-slate-500">
      <tr>
        <th class="px-3 py-2">姓名</th>
        <th class="px-3 py-2">公司</th>
        <th class="px-3 py-2">已玩</th>
        <th class="px-3 py-2">問卷</th>
      </tr>
    </thead>
    <tbody>
      <% for (const r of rows) { %>
        <tr class="border-t">
          <td class="px-3 py-2">
            <a class="font-medium underline" href="/admin/users/<%= encodeURIComponent(r.userId) %>"><%= r.name || "—" %></a>
          </td>
          <td class="px-3 py-2"><%= r.company || "—" %></td>
          <td class="px-3 py-2"><%= r.playedCount %></td>
          <td class="px-3 py-2">
            <% if (r.survey && r.surveyAnswerCount) { %>
              <span class="rounded bg-emerald-50 px-2 py-1 text-xs text-emerald-700">已填 (<%= r.surveyAnswerCount %> 項)</span>
            <% } else { %>
              <span class="rounded bg-slate-100 px-2 py-1 text-xs text-slate-600">未填</span>
            <% } %>
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<div id="clearModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/50 p-4">
  <div class="w-full max-w-md rounded-xl bg-white p-5 shadow-xl" role="dialog" aria-modal="true" aria-labelledby="clearModalTitle">
    <h3 id="clearModalTitle" class="text-lg font-semibold text-rose-700">⚠️ 清除所有資料</h3>
    <p class="mt-3 text-sm leading-relaxed text-slate-700">
      此操作會<strong class="text-rose-700">永久刪除</strong>以下 MongoDB collection 的<strong>全部</strong>資料，且<strong>無法復原</strong>：
    </p>
    <ul class="mt-2 list-inside list-disc text-sm text-slate-700">
      <li><code class="rounded bg-slate-100 px-1">users</code> — 用戶資料</li>
      <li><code class="rounded bg-slate-100 px-1">plays</code> — 已玩記錄</li>
      <li><code class="rounded bg-slate-100 px-1">surveys</code> — 問卷投票</li>
    </ul>
    <p class="mt-3 text-sm font-medium text-rose-800">請再三確認你真的要執行此操作。</p>

    <form id="clearForm" method="post" action="/admin/clear-data" class="mt-4 space-y-3">
      <label class="flex items-start gap-2 text-sm text-slate-700">
        <input id="clearUnderstood" type="checkbox" name="understood" class="mt-0.5" />
        <span>我明白此操作無法復原，並確認要刪除所有資料。</span>
      </label>

      <div>
        <label class="text-sm font-medium text-slate-700">輸入 <code class="rounded bg-slate-100 px-1">DELETE ALL</code> 以確認</label>
        <input
          id="clearConfirmText"
          name="confirmText"
          type="text"
          autocomplete="off"
          class="mt-1 w-full rounded-lg border px-3 py-2 text-sm"
          placeholder="DELETE ALL"
        />
      </div>

      <div>
        <label class="text-sm font-medium text-slate-700">再次輸入 Admin 密碼</label>
        <input
          id="clearPassword"
          name="password"
          type="password"
          autocomplete="current-password"
          class="mt-1 w-full rounded-lg border px-3 py-2 text-sm"
        />
      </div>

      <div class="flex gap-2 pt-1">
        <button
          type="button"
          id="btnCancelClear"
          class="flex-1 rounded-lg bg-white px-3 py-2 text-sm font-medium text-slate-900 ring-1 ring-slate-200 hover:bg-slate-50"
        >取消</button>
        <button
          id="btnConfirmClear"
          type="submit"
          disabled
          class="flex-1 rounded-lg bg-rose-600 px-3 py-2 text-sm font-medium text-white hover:bg-rose-700 disabled:cursor-not-allowed disabled:opacity-40"
        >確認刪除全部資料</button>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const modal = document.getElementById("clearModal");
    const form = document.getElementById("clearForm");
    const understood = document.getElementById("clearUnderstood");
    const confirmText = document.getElementById("clearConfirmText");
    const password = document.getElementById("clearPassword");
    const btnConfirm = document.getElementById("btnConfirmClear");

    function updateConfirmState() {
      const ok =
        understood.checked &&
        confirmText.value.trim() === "DELETE ALL" &&
        password.value.length > 0;
      btnConfirm.disabled = !ok;
    }

    function openModal() {
      form.reset();
      updateConfirmState();
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }

    function closeModal() {
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      form.reset();
      updateConfirmState();
    }

    document.getElementById("btnOpenClear").addEventListener("click", openModal);
    document.getElementById("btnCancelClear").addEventListener("click", closeModal);
    modal.addEventListener("click", (e) => {
      if (e.target === modal) closeModal();
    });
    understood.addEventListener("change", updateConfirmState);
    confirmText.addEventListener("input", updateConfirmState);
    password.addEventListener("input", updateConfirmState);

    form.addEventListener("submit", (e) => {
      if (!understood.checked || confirmText.value.trim() !== "DELETE ALL" || !password.value) {
        e.preventDefault();
        return;
      }
      if (!window.confirm("最後確認：你真的要刪除所有 users、plays、surveys 資料嗎？此操作無法復原。")) {
        e.preventDefault();
      }
    });
  })();
</script>

<%- include("partials/layout_bottom") %>
