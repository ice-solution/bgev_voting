<%- include("partials/layout_top", { title: t('profile.title'), showUserLogout: true }) %>

<div class="grid gap-4 md:grid-cols-3">
  <section class="md:col-span-2 rounded-xl border bg-white p-4">
    <h2 class="text-lg font-semibold"><%= t('profile.personal') %></h2>

    <% if (profileError) { %>
      <div class="mt-3 rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-800">
        <%= t('profile.profile_error', { error: profileError }) %>
      </div>
    <% } else { %>
      <dl class="mt-4 space-y-3">
        <div>
          <dt class="text-xs text-slate-500"><%= t('profile.name') %></dt>
          <dd class="text-base font-medium"><%= displayName || "—" %></dd>
        </div>
        <div>
          <dt class="text-xs text-slate-500"><%= t('profile.company') %></dt>
          <dd class="text-base font-medium"><%= displayCompany || "—" %></dd>
        </div>
      </dl>
    <% } %>
  </section>

  <aside class="rounded-xl border bg-white p-4">
    <% const totalGames = games.length || 1; const progressPct = Math.min(100, Math.round((playedCount / totalGames) * 100)); %>
    <div class="flex items-center justify-between text-sm">
      <span class="font-medium"><%= t('profile.progress') %></span>
      <span class="text-slate-600">
        <%= t('profile.played_count', { played: playedCount, total: games.length }) %>
      </span>
    </div>
    <div class="mt-3 h-3 w-full overflow-hidden rounded-full bg-slate-100">
      <div
        class="h-full rounded-full bg-emerald-500 transition-all duration-500"
        style="width: <%= progressPct %>%"
      ></div>
    </div>
    <div class="mt-1.5 text-right text-xs text-slate-500"><%= progressPct %>%</div>
    <div class="mt-2 text-xs text-slate-500"><%= t('profile.survey_hint', { min: surveyMinGames }) %></div>

    <div class="mt-4">
      <div class="text-sm font-medium"><%= t('profile.survey') %></div>
      <% if (!canSurvey) { %>
        <div class="mt-2 rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700">
          <%= t('profile.survey_not_eligible', { min: surveyMinGames }) %>
        </div>
      <% } else if (hasVoted) { %>
        <div class="mt-2 rounded-lg bg-emerald-50 px-3 py-2 text-sm text-emerald-800">
          <%= t('profile.survey_voted', { count: votedGames.length }) %>
        </div>
        <div class="mt-2 rounded-lg bg-amber-50 px-3 py-2 text-xs text-amber-900">
          <%= t('profile.survey_locked') %>
        </div>
        <ul class="mt-2 space-y-1 text-xs text-slate-600">
          <% for (const g of votedGames) { %>
            <li>• <%= g.name %> — <%= g.school_name %></li>
          <% } %>
        </ul>
      <% } else { %>
        <a href="/u/survey" class="mt-2 flex w-full items-center justify-center rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800"><%= t('profile.survey_fill') %></a>
      <% } %>
    </div>
  </aside>
</div>

<section class="mt-4 rounded-xl border bg-white p-4">
  <h3 class="text-lg font-semibold"><%= t('profile.played_games') %></h3>
  <div class="mt-3 grid gap-2 md:grid-cols-2">
    <% for (const g of games) { %>
      <div class="rounded-lg px-3 py-2 <%= g.played ? "bg-emerald-50" : "bg-slate-50" %>">
        <%- include("partials/game_item", { g, played: g.played }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include("partials/layout_bottom") %>
