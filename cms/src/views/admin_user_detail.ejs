<%- include("partials/layout_top", { title: "Admin - User" }) %>

<div class="flex items-start justify-between gap-3">
  <div>
    <div class="text-xs text-slate-500">userId</div>
    <h2 class="text-xl font-semibold"><%= userId %></h2>
  </div>
  <a class="rounded-lg bg-white px-3 py-2 text-sm font-medium text-slate-900 ring-1 ring-slate-200 hover:bg-slate-50" href="/admin/users">返回列表</a>
</div>

<div class="mt-4 grid gap-4 md:grid-cols-2">
  <section class="rounded-xl border bg-white p-4">
    <h3 class="text-sm font-semibold">外部個人資料</h3>
    <% if (user && user.profile) { %>
      <pre class="mt-2 max-h-80 overflow-auto rounded-xl bg-slate-50 p-3 text-xs"><%= JSON.stringify(user.profile, null, 2) %></pre>
    <% } else { %>
      <div class="mt-2 text-sm text-slate-600">（無）</div>
    <% } %>
  </section>

  <section class="rounded-xl border bg-white p-4">
    <h3 class="text-sm font-semibold">問卷</h3>
    <% if (survey && votedGames && votedGames.length) { %>
      <div class="mt-2 rounded-lg bg-emerald-50 px-3 py-2 text-sm text-emerald-800">
        已提交（<%= votedGames.length %> 項）
        <div class="mt-2 space-y-2">
          <% for (const g of votedGames) { %>
            <div><%- include("partials/game_item", { g }) %></div>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <div class="mt-2 rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700">未提交</div>
    <% } %>
  </section>
</div>

<section class="mt-4 rounded-xl border bg-white p-4">
  <h3 class="text-lg font-semibold">遊戲狀態</h3>
  <div class="mt-3 grid gap-2 md:grid-cols-2">
    <% for (const g of games) { %>
      <div class="rounded-lg px-3 py-2 <%= g.played ? "bg-emerald-50" : "bg-slate-50" %>">
        <%- include("partials/game_item", { g, played: g.played }) %>
      </div>
    <% } %>
  </div>
</section>

<%- include("partials/layout_bottom") %>

