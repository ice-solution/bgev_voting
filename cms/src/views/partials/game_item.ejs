<div class="min-w-0 <%= typeof extraClass !== 'undefined' ? extraClass : '' %>">
  <div class="flex items-start justify-between gap-2">
    <div class="min-w-0 flex-1">
      <div class="break-words text-sm font-medium leading-snug text-slate-900"><%= g.name %></div>
      <div class="mt-1 flex flex-wrap items-center gap-1.5">
        <span class="text-xs font-normal text-slate-400">#<%= g.id %></span>
        <% if (g.categoryLabel || g.category) { %>
          <span class="rounded bg-slate-200 px-1.5 py-0.5 text-xs text-slate-700"><%= g.categoryLabel || g.category %></span>
        <% } %>
      </div>
      <% if (g.school_name) { %>
        <div class="mt-0.5 truncate text-xs text-slate-500"><%= g.school_name %></div>
      <% } %>
    </div>
    <% if (typeof played !== 'undefined') { %>
      <div class="shrink-0 whitespace-nowrap pt-0.5 text-xs <%= played ? 'text-emerald-700' : 'text-slate-500' %>">
        <%= played ? t('game_played') : t('game_not_played') %>
      </div>
    <% } %>
  </div>
</div>
