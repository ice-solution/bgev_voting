<%- include("partials/layout_top", { title: t('home.title'), hideHeader: true, mainClass: "mx-auto max-w-md pb-8", pageBg: "bg-[#f7f3ef]" }) %>

<div class="flex justify-end px-3 pt-3">
  <%- include("partials/language_switcher", { redirectPath: "/" }) %>
</div>

<img
  src="/images/bgev.png"
  alt="<%= t('site_title') %>"
  class="w-full"
/>

<div class="px-3 pt-4">
<section class="rounded-2xl border border-orange-200 bg-white p-4 shadow-sm">
  <div class="inline-flex rounded-full bg-orange-100 px-2.5 py-1 text-xs font-medium text-orange-800"><%= t('home.badge') %></div>
  <h1 class="mt-2 text-lg font-bold leading-snug text-[#4a2c1a]"><%= t('home.title') %></h1>
  <p class="mt-1 text-sm text-slate-600"><%= t('home.intro') %></p>
</section>

<section class="mt-4 rounded-2xl border border-orange-200 bg-white p-4 shadow-sm">
  <h2 class="text-sm font-semibold text-[#4a2c1a]"><%= t('home.about_title') %></h2>
  <p class="mt-2 text-sm leading-relaxed text-slate-700">
    <%= t('home.about_body') %>
  </p>
</section>

<section class="mt-4 rounded-2xl border border-orange-200 bg-white p-4 shadow-sm">
  <h2 class="text-sm font-semibold text-[#4a2c1a]"><%= t('home.how_title') %></h2>
  <ol class="mt-3 space-y-3 text-sm text-slate-700">
    <li class="flex gap-3">
      <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#4a2c1a] text-xs font-semibold text-white">1</span>
      <span><%- t('home.step1') %></span>
    </li>
    <li class="flex gap-3">
      <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#4a2c1a] text-xs font-semibold text-white">2</span>
      <span><%- t('home.step2', { min: surveyMinGames }) %></span>
    </li>
    <li class="flex gap-3">
      <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-[#4a2c1a] text-xs font-semibold text-white">3</span>
      <span><%= t('home.step3') %></span>
    </li>
  </ol>
  <p class="mt-3 rounded-lg bg-orange-50 px-3 py-2 text-xs text-orange-900">
    <%= t('home.notice', { min: surveyMinGames }) %>
  </p>
</section>

<a
  href="/u"
  class="mt-5 flex w-full items-center justify-center rounded-2xl bg-[#4a2c1a] px-4 py-4 text-base font-semibold text-white shadow-md hover:bg-[#3d2415]"
>
  <%= t('home.scan_login') %>
</a>

<section class="mt-6">
  <h2 class="text-sm font-semibold text-[#4a2c1a]"><%= t('home.entries_title') %></h2>
  <% for (const group of categories) { %>
    <div class="mt-3 rounded-2xl border border-orange-200 bg-white p-4 shadow-sm">
      <div class="text-sm font-semibold text-orange-800"><%= group.categoryLabel %></div>
      <ul class="mt-2 divide-y divide-slate-100">
        <% for (const g of group.games) { %>
          <li class="py-2.5">
            <div class="text-sm font-medium text-slate-900"><%= g.name %></div>
            <div class="mt-0.5 text-xs text-slate-500"><%= g.school_name %></div>
          </li>
        <% } %>
      </ul>
    </div>
  <% } %>
</section>

</div>

<%- include("partials/layout_bottom") %>
