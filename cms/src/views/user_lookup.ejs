<%- include("partials/layout_top", { title: "掃描登入" }) %>

<div class="mx-auto max-w-md space-y-4">
  <section class="rounded-xl border bg-white p-4">
    <h2 class="text-lg font-semibold">掃描 QR Code 登入</h2>
    <p class="mt-1 text-sm text-slate-600">請使用相機掃描你的 QR Code 以查看個人資料與遊戲進度。</p>

    <% if (error) { %>
      <div class="mt-3 rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-800"><%= error %></div>
    <% } %>
  </section>

  <section class="rounded-xl border bg-white p-4">
    <div id="iframeNotice" class="hidden"></div>
    <div class="text-sm font-medium">相機掃描</div>
    <button id="btnStartCam" class="mt-3 w-full rounded-lg bg-slate-900 px-3 py-3 text-sm font-medium text-white hover:bg-slate-800">開始掃描</button>

    <div id="qrWrap" class="mt-3 hidden overflow-hidden rounded-xl border bg-slate-900">
      <div id="qr" class="w-full"></div>
    </div>

    <button id="btnStopCam" class="mt-3 hidden w-full rounded-lg bg-white px-3 py-3 text-sm font-medium text-slate-900 ring-1 ring-slate-200 hover:bg-slate-50">關閉鏡頭</button>

    <div id="msg" class="mt-3 hidden rounded-lg px-3 py-2 text-sm"></div>

    <p id="scanHint" class="mt-3 text-center text-xs text-slate-500">按「開始掃描」啟動相機</p>
    <p class="mt-2 text-center text-xs text-slate-500">如 iOS 未授權相機，請到 Safari 設定允許相機。</p>
  </section>
</div>

<%- include("partials/qr_scanner_scripts") %>
<script>
  const msgEl = document.getElementById("msg");

  function showMsg(text, type) {
    if (!msgEl) return;
    msgEl.textContent = text;
    msgEl.classList.remove("hidden", "bg-emerald-50", "text-emerald-800", "bg-rose-50", "text-rose-800", "bg-slate-50", "text-slate-600");
    if (type === "success") msgEl.classList.add("bg-emerald-50", "text-emerald-800");
    else if (type === "error") msgEl.classList.add("bg-rose-50", "text-rose-800");
    else msgEl.classList.add("bg-slate-50", "text-slate-600");
  }

  function extractUserId(text) {
    const raw = (text || "").trim();
    if (!raw) return "";
    try {
      const u = new URL(raw);
      const parts = u.pathname.split("/").filter(Boolean);
      return parts[parts.length - 1] || raw;
    } catch (_) {
      return raw;
    }
  }

  if (window.QrScanner) {
    QrScanner.mountIframeNotice("iframeNotice");
    QrScanner.createScanner({
      mountId: "qr",
      btnStart: document.getElementById("btnStartCam"),
      btnStop: document.getElementById("btnStopCam"),
      qrWrap: document.getElementById("qrWrap"),
      scanHint: document.getElementById("scanHint"),
      showMsg,
      onDecoded: async (decodedText) => {
        const userId = extractUserId(decodedText);
        if (!userId) {
          showMsg("無法辨識 QR Code 內容，請再試一次。", "error");
          return;
        }
        showMsg("掃描成功，正在登入...", "success");
        window.location.replace("/u/enter/" + encodeURIComponent(userId));
      }
    });
  }
</script>

<%- include("partials/layout_bottom") %>
