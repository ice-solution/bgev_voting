<%- include("partials/layout_top", { title: "問卷投票", showUserLogout: true, mainClass: "mx-auto max-w-md pb-28", pageBg: "bg-[#f7f3ef]" }) %>

<div class="px-3 pt-2">
  <a href="/u/profile" class="text-sm text-slate-600 hover:underline">← 返回我的資料</a>

  <section class="mt-3 rounded-2xl border border-orange-200 bg-white p-4 shadow-sm">
    <h1 class="text-lg font-bold text-[#4a2c1a]">你喜歡那個遊戲？</h1>
    <p class="mt-1 text-sm text-slate-600">可按組別展開，點選喜歡的遊戲（可多選）。</p>
    <% if (hasVoted) { %>
      <div class="mt-3 rounded-lg bg-emerald-50 px-3 py-2 text-xs text-emerald-800">
        你已提交投票，可修改選擇後再次提交。
      </div>
    <% } %>
  </section>

  <div class="mt-4 space-y-3">
    <% categories.forEach((group, idx) => { %>
      <div class="overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
        <button
          type="button"
          class="accordion-btn flex w-full items-center gap-3 px-4 py-3 text-left"
          data-target="panel-<%= idx %>"
          aria-expanded="false"
        >
          <span class="accordion-icon flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-blue-500 text-lg font-medium leading-none text-white">+</span>
          <span class="text-sm font-semibold text-slate-800"><%= group.category %></span>
          <span class="category-count ml-auto text-xs text-slate-400">0 已選</span>
        </button>
        <div id="panel-<%= idx %>" class="accordion-panel hidden border-t border-slate-100 px-3 py-3" data-category="<%= group.category %>">
          <div class="grid grid-cols-2 gap-2">
            <% for (const g of group.games) { %>
              <button
                type="button"
                class="game-option rounded-lg border border-slate-200 bg-white px-2 py-3 text-left transition hover:border-slate-300"
                data-id="<%= g.id %>"
                data-category="<%= group.category %>"
              >
                <div class="text-xs font-semibold leading-snug text-slate-900"><%= g.name %></div>
                <div class="mt-1 text-[10px] leading-tight text-slate-500"><%= g.school_name %></div>
              </button>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>

<div class="fixed bottom-0 left-0 right-0 border-t border-slate-200 bg-white px-4 py-3">
  <div class="mx-auto max-w-md">
    <div id="selectedSummary" class="mb-2 text-center text-xs text-slate-500">已選 0 個遊戲</div>
    <button id="btnSubmit" class="w-full rounded-xl bg-[#4a2c1a] px-4 py-3 text-sm font-semibold text-white hover:bg-[#3d2415]">提交投票</button>
  </div>
</div>

<div id="successModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40 px-4">
  <div class="w-full max-w-xs rounded-2xl bg-white p-6 text-center shadow-xl">
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-emerald-100 text-2xl text-emerald-600">✓</div>
    <h2 class="mt-4 text-lg font-bold text-slate-900">投票成功</h2>
    <p class="mt-2 text-sm text-slate-600">感謝你的參與！</p>
    <button id="btnModalOk" class="mt-5 w-full rounded-xl bg-[#4a2c1a] px-4 py-3 text-sm font-semibold text-white">返回我的資料</button>
  </div>
</div>

<script>
  const initialSelected = new Set(<%= JSON.stringify(selectedIds) %>);
  const selected = new Set(initialSelected);

  function updateCategoryCounts() {
    document.querySelectorAll(".accordion-panel").forEach((panel) => {
      const cat = panel.dataset.category;
      const count = [...selected].filter((id) => {
        const btn = document.querySelector('.game-option[data-id="' + id + '"]');
        return btn && btn.dataset.category === cat;
      }).length;
      const header = panel.previousElementSibling;
      const countEl = header && header.querySelector(".category-count");
      if (countEl) countEl.textContent = count + " 已選";
    });
    const summary = document.getElementById("selectedSummary");
    if (summary) summary.textContent = "已選 " + selected.size + " 個遊戲";
  }

  function syncOptionStyles() {
    document.querySelectorAll(".game-option").forEach((btn) => {
      const id = Number(btn.dataset.id);
      const on = selected.has(id);
      btn.classList.toggle("border-emerald-500", on);
      btn.classList.toggle("bg-emerald-50", on);
      btn.classList.toggle("ring-2", on);
      btn.classList.toggle("ring-emerald-200", on);
    });
    updateCategoryCounts();
  }

  document.querySelectorAll(".accordion-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const panel = document.getElementById(btn.dataset.target);
      const icon = btn.querySelector(".accordion-icon");
      const open = panel.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", open ? "true" : "false");
      if (icon) icon.textContent = open ? "−" : "+";
    });
  });

  document.querySelectorAll(".game-option").forEach((btn) => {
    btn.addEventListener("click", () => {
      const id = Number(btn.dataset.id);
      if (selected.has(id)) selected.delete(id);
      else selected.add(id);
      syncOptionStyles();
    });
  });

  document.getElementById("btnSubmit").addEventListener("click", async () => {
    if (!selected.size) {
      alert("請至少選擇一個遊戲");
      return;
    }
    const btn = document.getElementById("btnSubmit");
    btn.disabled = true;
    btn.textContent = "提交中...";
    const res = await fetch("/api/user/survey", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      credentials: "same-origin",
      body: JSON.stringify({ answerGameIds: [...selected] })
    });
    const data = await res.json().catch(() => ({}));
    btn.disabled = false;
    btn.textContent = "提交投票";
    if (!data.ok) {
      alert("提交失敗: " + (data.error || res.status));
      return;
    }
    const modal = document.getElementById("successModal");
    modal.classList.remove("hidden");
    modal.classList.add("flex");
  });

  document.getElementById("btnModalOk").addEventListener("click", () => {
    location.href = "/u/profile";
  });

  syncOptionStyles();
  if (initialSelected.size > 0) {
    document.querySelectorAll(".accordion-panel").forEach((panel) => {
      const hasSelected = [...panel.querySelectorAll(".game-option")].some((btn) =>
        selected.has(Number(btn.dataset.id))
      );
      if (hasSelected) {
        panel.classList.remove("hidden");
        const header = panel.previousElementSibling;
        const icon = header && header.querySelector(".accordion-icon");
        if (header) header.setAttribute("aria-expanded", "true");
        if (icon) icon.textContent = "−";
      }
    });
  }
</script>

<%- include("partials/layout_bottom") %>
