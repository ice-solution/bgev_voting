<%- include("partials/layout_top", { title: "Staff 掃描" }) %>

<div class="mx-auto max-w-md space-y-4">
  <section class="rounded-xl border bg-white p-4">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h2 class="text-lg font-semibold">Staff 掃描</h2>
        <p class="mt-1 text-sm text-slate-600">選擇遊戲後，掃描用戶 QR Code 記錄「已玩」。</p>
        <div class="mt-2 inline-flex rounded-full bg-orange-100 px-2.5 py-1 text-xs font-medium text-orange-800">
          <%= categoryLabel %>
        </div>
      </div>
      <a class="shrink-0 rounded-lg bg-white px-3 py-2 text-sm font-medium text-slate-900 ring-1 ring-slate-200 hover:bg-slate-50" href="/">返回</a>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="mt-3 rounded-lg bg-rose-50 px-3 py-2 text-sm text-rose-800"><%= error %></div>
    <% } %>
  </section>

  <% if (!authed) { %>
    <section class="rounded-xl border bg-slate-50 p-4">
      <form method="post" action="/staff/group/<%= groupId %>/login">
        <div class="text-sm font-medium">Staff 登入</div>
        <div class="mt-1 text-sm text-slate-600">請輸入 staff token 登入（每個 browser session 只需登入一次）。</div>
        <input name="token" class="mt-3 w-full rounded-lg border px-3 py-2" placeholder="STAFF_TOKEN" autocomplete="off" />
        <button class="mt-3 w-full rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:bg-slate-800" type="submit">登入</button>
      </form>
    </section>
  <% } else { %>
    <section class="rounded-xl border bg-white p-4">
      <div class="flex items-center justify-between gap-2">
        <div class="text-sm font-medium text-emerald-700">已登入</div>
        <form method="post" action="/staff/logout">
          <input type="hidden" name="groupId" value="<%= groupId %>" />
          <button class="rounded-lg bg-white px-3 py-1.5 text-xs font-medium text-slate-900 ring-1 ring-slate-200 hover:bg-slate-50" type="submit">登出</button>
        </form>
      </div>

      <div class="mt-4">
        <label for="gameSelect" class="text-sm font-medium text-slate-700">遊戲</label>
        <select id="gameSelect" class="mt-1 w-full rounded-lg border px-3 py-2 text-sm">
          <option value="">請選擇遊戲</option>
          <% for (const g of games) { %>
            <option value="<%= g.id %>"><%= g.name %> (#<%= g.id %>)</option>
          <% } %>
        </select>
      </div>

      <div id="selectedGameInfo" class="mt-4 hidden rounded-lg bg-slate-50 px-3 py-2 text-sm text-slate-700"></div>
    </section>

    <section id="scanSection" class="hidden rounded-xl border bg-white p-4">
      <div id="iframeNotice" class="hidden"></div>
      <div class="text-sm font-medium">相機掃描</div>
      <button id="btnStartCam" class="mt-3 w-full rounded-lg bg-slate-900 px-3 py-3 text-sm font-medium text-white hover:bg-slate-800">開始掃描</button>

      <div id="qrWrap" class="mt-3 hidden overflow-hidden rounded-xl border bg-slate-900">
        <div id="qr" class="w-full"></div>
      </div>

      <button id="btnStopCam" class="mt-3 hidden w-full rounded-lg bg-white px-3 py-3 text-sm font-medium text-slate-900 ring-1 ring-slate-200 hover:bg-slate-50">關閉鏡頭</button>

      <div id="msg" class="mt-3 hidden rounded-lg px-3 py-2 text-sm"></div>

      <p id="scanHint" class="mt-3 text-center text-xs text-slate-500">按「開始掃描」啟動相機</p>
    </section>
  <% } %>
</div>

<% if (authed) { %>
<%- include("partials/scanner_i18n") %>
<%- include("partials/qr_scanner_scripts") %>
<script>
  const gamesData = <%- JSON.stringify(games) %>;
  const scannerI18n = window.__scannerI18n || {};

  const gameSelect = document.getElementById("gameSelect");
  const selectedGameInfo = document.getElementById("selectedGameInfo");
  const scanSection = document.getElementById("scanSection");
  const msgEl = document.getElementById("msg");

  let selectedGameId = null;
  let scannerApi = null;

  function showMsg(text, type) {
    if (!msgEl) return;
    msgEl.textContent = text;
    msgEl.classList.remove("hidden", "bg-emerald-50", "text-emerald-800", "bg-rose-50", "text-rose-800", "bg-slate-50", "text-slate-600");
    if (type === "success") msgEl.classList.add("bg-emerald-50", "text-emerald-800");
    else if (type === "error") msgEl.classList.add("bg-rose-50", "text-rose-800");
    else msgEl.classList.add("bg-slate-50", "text-slate-600");
  }

  function extractUserId(text) {
    const raw = (text || "").trim();
    if (!raw) return "";
    try {
      const u = new URL(raw);
      const parts = u.pathname.split("/").filter(Boolean);
      return parts[parts.length - 1] || raw;
    } catch (_) {
      return raw;
    }
  }

  async function stopScannerIfNeeded() {
    if (scannerApi && scannerApi.stopCamera) {
      await scannerApi.stopCamera();
    }
  }

  function updateSelectedGame() {
    selectedGameId = gameSelect.value ? Number(gameSelect.value) : null;
    if (!selectedGameId) {
      selectedGameInfo.classList.add("hidden");
      scanSection.classList.add("hidden");
      stopScannerIfNeeded();
      return;
    }
    const game = gamesData.find((g) => Number(g.id) === selectedGameId);
    if (!game) return;
    selectedGameInfo.classList.remove("hidden");
    selectedGameInfo.innerHTML =
      '<div class="font-medium">' + game.name + ' <span class="text-slate-400">#' + game.id + "</span></div>" +
      (game.school_name ? '<div class="mt-0.5 text-xs text-slate-500">' + game.school_name + "</div>" : "");
    scanSection.classList.remove("hidden");
    if (msgEl) {
      msgEl.classList.add("hidden");
      msgEl.textContent = "";
    }
  }

  gameSelect.addEventListener("change", async () => {
    await stopScannerIfNeeded();
    updateSelectedGame();
  });

  if (window.QrScanner) {
    QrScanner.mountIframeNotice("iframeNotice", scannerI18n);
    scannerApi = QrScanner.createScanner({
      mountId: "qr",
      btnStart: document.getElementById("btnStartCam"),
      btnStop: document.getElementById("btnStopCam"),
      qrWrap: document.getElementById("qrWrap"),
      scanHint: document.getElementById("scanHint"),
      i18n: scannerI18n,
      showMsg,
      onDecoded: async (decodedText) => {
        if (!selectedGameId) {
          showMsg("請先選擇遊戲", "error");
          return;
        }
        const clean = extractUserId(decodedText);
        if (!clean) {
          showMsg("無法辨識 QR Code 內容", "error");
          return;
        }
        const res = await fetch("/api/staff/" + encodeURIComponent(selectedGameId) + "/confirm", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "same-origin",
          body: JSON.stringify({ userId: clean })
        });
        const data = await res.json().catch(() => ({}));
        if (!data.ok) {
          const failTpl = scannerI18n.staffFail || "失敗：{{error}}";
          showMsg(failTpl.replace("{{error}}", data.error || res.status), "error");
          return;
        }
        const suffix = data.duplicated ? (scannerI18n.staffDuplicated || "（此用戶已記錄）") : "";
        showMsg((scannerI18n.staffSuccess || "掃描成功！") + suffix, "success");
      }
    });
  }
</script>
<% } %>

<%- include("partials/layout_bottom") %>
