## Server
PORT=8787
BASE_URL=http://localhost:8787
SESSION_SECRET=change-me
# 反向代理（nginx）後需啟用，否則 rate-limit 會報 X-Forwarded-For 警告
# TRUST_PROXY=1

## MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=bgev_event

## External RSVP API (curl example)
# curl -H "X-WEB-API-KEY: your-real-key" "https://{{RSVP_DOMAIN}}/web/{{RSVP_EVENT_ID}}/users/{{userid}}"
# RSVP_DOMAIN 只填 hostname（本機可用 localhost:3377，會自動用 http）
RSVP_DOMAIN=demo.brandactivation.hk
RSVP_EVENT_ID=yourEventId
# 用戶掃描後，伺服器用此 key 代為呼叫 RSVP（預設取 WEB_API_KEYS 第一個）
RSVP_API_KEY=your-real-key
WEB_API_KEYS=your-real-key
# 本機 RSVP 可選填 http，留空則 localhost 自動用 http
# RSVP_PROTOCOL=http

## Survey rules
SURVEY_MIN_GAMES=3
SURVEY_MAX_VOTES=3
# 投票截止（香港時間 GMT+8），可填日期+時間，方便延長
# 格式：YYYY-MM-DD HH:mm  或  YYYY-MM-DDTHH:mm  或只填日期（預設 15:00）
VOTE_DEADLINE=2026-06-15 15:00

## Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

## Staff (simple shared token, optional but recommended)
STAFF_TOKEN=change-me

## iframe 嵌入（若網站會被其他 domain 用 iframe 包著）
# 父頁面 iframe 需加 allow="camera"，例：
# <iframe src="https://your-cms.com/staff/group/1" allow="camera" ...></iframe>
# /staff/group/1 中學一組 | /staff/group/2 中學二組 | /staff/group/3 大專組
ALLOW_IFRAME_CAMERA=true
FRAME_ANCESTORS=*
# 跨網域 iframe 時 session 需設定（必須 HTTPS）：
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
